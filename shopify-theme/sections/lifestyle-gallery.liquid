<section class="section">
  <div class="page-width stack">
    <div class="stack">
      <span class="eyebrow">{{ section.settings.eyebrow }}</span>
      <h2>{{ section.settings.heading }}</h2>
    </div>
    <div class="gallery-grid grid">
      {%- for block in section.blocks -%}
        <figure class="media-shell" style="aspect-ratio: {{ block.settings.aspect_ratio }};" {{ block.shopify_attributes }}>
          {%- if block.settings.image != blank -%}
            {{ block.settings.image | image_url: width: 1200 | image_tag: loading: 'lazy', widths: '320,480,720,960,1200', alt: block.settings.caption }}
          {%- else -%}
            {{ 'lifestyle-2' | placeholder_svg_tag: 'placeholder-svg' }}
          {%- endif -%}
        </figure>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Lifestyle gallery",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Editorial Gallery" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Gemacht für Tisch, Desk, Sofa und jede kleine Pause dazwischen." }
  ],
  "blocks": [
    {
      "type": "image",
      "name": "Image",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "caption", "label": "Caption" },
        { "type": "text", "id": "aspect_ratio", "label": "Aspect ratio", "default": "1 / 1" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Lifestyle gallery",
      "blocks": [
        { "type": "image", "settings": { "aspect_ratio": "1.5 / 1" } },
        { "type": "image", "settings": { "aspect_ratio": "1 / 1" } },
        { "type": "image", "settings": { "aspect_ratio": "1 / 1" } },
        { "type": "image", "settings": { "aspect_ratio": "1.2 / 1" } }
      ]
    }
  ]
}
{% endschema %}
