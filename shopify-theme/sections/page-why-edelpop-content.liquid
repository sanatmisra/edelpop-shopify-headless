<section class="section">
  <div class="page-width stack">
    <div class="page-hero">
      <div class="page-hero__shell card">
        <div class="stack">
          <span class="eyebrow">Why Edelpop</span>
          <h1>{{ section.settings.heading }}</h1>
          <p class="lead">{{ section.settings.intro }}</p>
        </div>
        <div class="media-shell" style="aspect-ratio: 1 / 1;">{{ 'product-2' | placeholder_svg_tag: 'placeholder-svg' }}</div>
      </div>
    </div>
    <div class="benefits-grid grid">
      {%- for block in section.blocks -%}
        <div class="card" style="padding: 1rem;" {{ block.shopify_attributes }}>
          <div class="stack">
            <span class="eyebrow">{{ block.settings.kicker }}</span>
            <h3>{{ block.settings.title }}</h3>
            <p>{{ block.settings.text }}</p>
          </div>
        </div>
      {%- endfor -%}
    </div>
    <div class="accordion">
      <div class="accordion__item is-open">
        <button class="accordion__button" type="button" data-accordion-button aria-expanded="true">Was ist Makhana? {% render 'icon', icon: 'chevron-down' %}</button>
        <div class="accordion__content"><p>Makhana, auch Foxnuts genannt, sind die Basis von Edelpop: leicht, knusprig und ideal für modernes Snacking mit mehr Charakter als klassische Standard-Snacks.</p></div>
      </div>
      <div class="accordion__item">
        <button class="accordion__button" type="button" data-accordion-button aria-expanded="false">Warum wirkt Edelpop anders? {% render 'icon', icon: 'chevron-down' %}</button>
        <div class="accordion__content"><p>Weil Sorte, Textur, Design und Markenmoment sauber zusammenarbeiten: weniger generisch, mehr Haltung, mehr Wiedererkennung.</p></div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Why Edelpop content",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Was Makhana besonders macht und warum Edelpop daraus einen moderneren Snack macht." },
    { "type": "textarea", "id": "intro", "label": "Intro", "default": "Diese Seite erklärt Makhana so, wie Edelpop gedacht ist: hochwertig, verständlich und mit klarem Mehrwert für den Alltag." }
  ],
  "blocks": [
    {
      "type": "point",
      "name": "Point",
      "settings": [
        { "type": "text", "id": "kicker", "label": "Kicker", "default": "Makhana" },
        { "type": "text", "id": "title", "label": "Title", "default": "Geröstet statt frittiert" },
        { "type": "textarea", "id": "text", "label": "Text", "default": "Ein moderner Premium-Snack mit leichterem Gefühl und mehr Charakter im Crunch." }
      ]
    }
  ]
}
{% endschema %}
