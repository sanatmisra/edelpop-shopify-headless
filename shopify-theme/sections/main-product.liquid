<section class="section">
  <div class="page-width">
    <div class="product-page">
      <div class="stack">
        <div class="product-gallery">
          {%- for media in product.media -%}
            <div class="product-gallery__item" tabindex="0">
              {{ media | image_url: width: 1400 | image_tag: loading: 'lazy', widths: '480,720,960,1200,1400', alt: media.alt | default: product.title }}
            </div>
          {%- else -%}
            <div class="product-gallery__item">{{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}</div>
          {%- endfor -%}
        </div>
      </div>

      <div class="product-buybox card">
        <div class="stack">
          <span class="eyebrow">{{ product.vendor | default: shop.name }}</span>
          <h1>{{ product.title }}</h1>
          <p class="lead">{{ product.metafields.custom.short_descriptor.value | default: 'product.descriptor' | t }}</p>
        </div>
        <div class="product-price-row">
          <div class="stack" style="gap: 0.25rem;">
            <span class="price">{{ product.price | money }}</span>
            <span class="product-tax-note">{{ 'product.tax_note' | t }}</span>
          </div>
          {%- if product.compare_at_price > product.price -%}
            <span class="badge">{{ 'general.labels.save' | t }}</span>
          {%- endif -%}
        </div>
        <div class="pill-row product-benefits-pills">
          <span class="badge badge--subtle">{{ 'product.benefits.roasted' | t }}</span>
          <span class="badge badge--subtle">{{ 'product.benefits.light' | t }}</span>
          <span class="badge badge--subtle">{{ 'product.benefits.routine' | t }}</span>
        </div>
        <div class="product-service-strip">
          <span>{{ 'product.service.shipping' | t }}</span>
          <span>{{ 'product.service.returns' | t }}</span>
        </div>

        {% form 'product', product, class: 'product-form' %}
          {%- unless product.has_only_default_variant -%}
            <div class="field">
              <label for="VariantSelect">{{ product.options_with_values.first.name }}</label>
              <select id="VariantSelect" name="id">
                {%- for variant in product.variants -%}
                  <option value="{{ variant.id }}" {% if variant == product.selected_or_first_available_variant %}selected{% endif %}>
                    {{ variant.title }} · {{ variant.price | money }}
                  </option>
                {%- endfor -%}
              </select>
            </div>
          {%- else -%}
            <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
          {%- endunless -%}

          <div class="product-form__actions">
            <div class="qty-selector">
              <button type="button" data-qty-button="-1" aria-label="Minus">{% render 'icon', icon: 'minus' %}</button>
              <input type="number" name="quantity" value="1" min="1" aria-label="{{ 'product.quantity' | t }}">
              <button type="button" data-qty-button="1" aria-label="Plus">{% render 'icon', icon: 'plus' %}</button>
            </div>
            <button type="submit" class="btn btn--primary">{{ 'general.buttons.add_to_cart' | t }}</button>
          </div>
        {% endform %}

        <div class="accordion">
          <div class="accordion__item is-open">
            <button class="accordion__button" type="button" data-accordion-button aria-expanded="true">{{ 'product.flavor_notes' | t }} {% render 'icon', icon: 'chevron-down' %}</button>
            <div class="accordion__content"><p>{{ product.metafields.custom.flavor_notes.value | default: 'Klar im Geschmack, sauber im Finish und gemacht für den schnellen nächsten Griff.' }}</p></div>
          </div>
          <div class="accordion__item">
            <button class="accordion__button" type="button" data-accordion-button aria-expanded="false">{{ 'product.texture_notes' | t }} {% render 'icon', icon: 'chevron-down' %}</button>
            <div class="accordion__content"><p>{{ product.metafields.custom.texture_notes.value | default: 'Leicht, geröstet und angenehm knusprig, ohne schwer zu wirken.' }}</p></div>
          </div>
          <div class="accordion__item">
            <button class="accordion__button" type="button" data-accordion-button aria-expanded="false">{{ 'product.ingredients' | t }} {% render 'icon', icon: 'chevron-down' %}</button>
            <div class="accordion__content"><p>{{ product.description | strip_html | default: 'Hier lassen sich Zutaten, Allergenhinweise und Produktdetails für Edelpop sauber ergänzen.' }}</p></div>
          </div>
          <div class="accordion__item">
            <button class="accordion__button" type="button" data-accordion-button aria-expanded="false">{{ 'product.shipping' | t }} {% render 'icon', icon: 'chevron-down' %}</button>
            <div class="accordion__content"><p>Versand innerhalb Deutschlands, klare Lieferinfos und ein Checkout, der auf mobile Routinen ausgelegt ist.</p></div>
          </div>
        </div>

        <div class="sticky-atc">
          <div>
            <strong>{{ product.title }}</strong>
            <div class="price">{{ product.price | money }}</div>
          </div>
          <button class="btn btn--primary" type="button" data-sticky-atc>{{ 'general.buttons.add_to_cart' | t }}</button>
        </div>
      </div>
    </div>

    {%- assign related_collection = product.collections.first -%}
    {%- if related_collection != blank and related_collection.products_count > 1 -%}
      <div class="section stack">
        <div class="stack">
          <span class="eyebrow">{{ 'product.related' | t }}</span>
          <h2>{{ 'product.related' | t }}</h2>
        </div>
        <div class="product-grid grid">
          {%- for related_product in related_collection.products limit: 4 -%}
            {%- unless related_product.id == product.id -%}
              {% render 'product-card', product: related_product %}
            {%- endunless -%}
          {%- endfor -%}
        </div>
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Main product",
  "settings": []
}
{% endschema %}
