<section class="section">
  <div class="page-width stack">
    <div class="page-hero">
      <div class="page-hero__shell card">
        <div class="stack">
          <span class="eyebrow">Handel</span>
          <h1>{{ section.settings.heading }}</h1>
          <p class="lead">{{ section.settings.intro }}</p>
          <a class="btn btn--primary" href="/pages/contact">Jetzt Händler werden</a>
        </div>
        <div class="media-shell" style="aspect-ratio: 1 / 1;">{{ 'product-3' | placeholder_svg_tag: 'placeholder-svg' }}</div>
      </div>
    </div>
    <div class="benefits-grid grid">
      {%- for block in section.blocks -%}
        <div class="card" style="padding: 1rem;" {{ block.shopify_attributes }}>
          <div class="stack">
            <span class="eyebrow">{{ block.settings.kicker }}</span>
            <h3>{{ block.settings.title }}</h3>
            <p>{{ block.settings.text }}</p>
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Wholesale content",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Edelpop für Regal, Theke und eine modernere Snack-Kategorie." },
    { "type": "textarea", "id": "intro", "label": "Intro", "default": "Für Händler entwickelt, die gerösteten Premium-Crunch mit starker Regalwirkung und klarer Story suchen." }
  ],
  "blocks": [
    {
      "type": "point",
      "name": "Point",
      "settings": [
        { "type": "text", "id": "kicker", "label": "Kicker", "default": "Regal" },
        { "type": "text", "id": "title", "label": "Title", "default": "Retail-ready Packaging" },
        { "type": "textarea", "id": "text", "label": "Text", "default": "Klare Front-of-pack Story, gute Range-Logik und ein Look, der im Regal sofort hängen bleibt." }
      ]
    }
  ]
}
{% endschema %}
