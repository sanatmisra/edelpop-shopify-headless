<section class="section">
  <div class="page-width stack">
    <div class="page-hero">
      <div class="page-hero__shell card">
        <div class="stack">
          <span class="eyebrow">Über Edelpop</span>
          <h1>{{ section.settings.heading }}</h1>
          <p class="lead">{{ section.settings.intro }}</p>
        </div>
        <div class="media-shell" style="aspect-ratio: 1 / 1;">
          {%- if section.settings.image != blank -%}
            {{ section.settings.image | image_url: width: 1200 | image_tag: loading: 'lazy', widths: '480,720,960,1200', alt: section.settings.heading }}
          {%- else -%}
            {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
          {%- endif -%}
        </div>
      </div>
    </div>
    <div class="grid" style="grid-template-columns: 1fr; gap: 1rem;">
      {%- for block in section.blocks -%}
        <div class="card" style="padding: 1.25rem;" {{ block.shopify_attributes }}>
          <div class="stack">
            <span class="eyebrow">{{ block.settings.kicker }}</span>
            <h3>{{ block.settings.title }}</h3>
            <p>{{ block.settings.text }}</p>
          </div>
        </div>
      {%- endfor -%}
    </div>
    <a class="btn btn--primary" href="/collections/all">Jetzt entdecken</a>
  </div>
</section>

{% schema %}
{
  "name": "About content",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Warum Edelpop existiert" },
    { "type": "textarea", "id": "intro", "label": "Intro", "default": "Edelpop bringt gerösteten Makhana in eine Form, die leicht, modern und retail-ready wirkt, ohne beliebig zu werden." },
    { "type": "image_picker", "id": "image", "label": "Image" }
  ],
  "blocks": [
    {
      "type": "story",
      "name": "Story block",
      "settings": [
        { "type": "text", "id": "kicker", "label": "Kicker", "default": "Philosophie" },
        { "type": "text", "id": "title", "label": "Title", "default": "Snack neu gedacht" },
        { "type": "textarea", "id": "text", "label": "Text", "default": "Nicht generisch gesund, nicht billig laut, sondern warm, modern und klar premium in der Wirkung." }
      ]
    }
  ]
}
{% endschema %}
