{%- if section.settings.show_announcement -%}
  <section class="announcement-bar" role="region" aria-label="{{ section.settings.text | escape }}">
    <div class="page-width announcement-bar__inner">
      <span>{{ section.settings.text }}</span>
      {%- if section.settings.link != blank and section.settings.link_label != blank -%}
        <a href="{{ section.settings.link }}"><strong>{{ section.settings.link_label }}</strong></a>
      {%- endif -%}
    </div>
  </section>
{%- endif -%}

{% schema %}
{
  "name": "Announcement bar",
  "settings": [
    { "type": "checkbox", "id": "show_announcement", "label": "Show announcement", "default": true },
    { "type": "text", "id": "text", "label": "Text", "default": "Edelpop startet bald in Deutschland. Retail- und Wholesale-Anfragen sind jetzt offen." },
    { "type": "text", "id": "link_label", "label": "Link label", "default": "Für Händler" },
    { "type": "url", "id": "link", "label": "Link" }
  ]
}
{% endschema %}
