<section class="section">
  <div class="page-width stack">
    <div class="page-hero">
      <div class="page-hero__shell card">
        <div class="stack">
          <span class="eyebrow">Bundles</span>
          <h1>{{ section.settings.heading }}</h1>
          <p class="lead">{{ section.settings.intro }}</p>
        </div>
        <div class="media-shell" style="aspect-ratio: 1 / 1;">{{ 'product-2' | placeholder_svg_tag: 'placeholder-svg' }}</div>
      </div>
    </div>
    <div class="product-grid grid">
      {%- assign source_collection = section.settings.collection -%}
      {%- if source_collection != blank and source_collection.products_count > 0 -%}
        {%- for product in source_collection.products limit: 4 -%}
          {% render 'product-card', product: product %}
        {%- endfor -%}
      {%- else -%}
        {%- for i in (1..3) -%}
          <article class="product-card card">
            <div class="product-card__media media-shell">{{ 'product-3' | placeholder_svg_tag: 'placeholder-svg' }}</div>
            <div class="product-card__content stack">
              <h3>Bundle {{ i }}</h3>
              <p>Probieren, teilen oder verschenken.</p>
              <span class="price">€12,90</span>
            </div>
          </article>
        {%- endfor -%}
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Bundles content",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Probierpakete mit klarer Merchandising-Story." },
    { "type": "textarea", "id": "intro", "label": "Intro", "default": "Für Erstkauf, Geschenk oder den schnellsten Einstieg in die ganze Range." },
    { "type": "collection", "id": "collection", "label": "Collection" }
  ]
}
{% endschema %}
