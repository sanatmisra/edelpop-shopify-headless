<section class="section">
  <div class="page-width stack">
    <div class="stack">
      <span class="eyebrow">FAQ</span>
      <h1>{{ section.settings.heading }}</h1>
      <p class="lead">{{ section.settings.intro }}</p>
    </div>
    <div class="accordion">
      {%- for block in section.blocks -%}
        <div class="accordion__item {% if forloop.first %}is-open{% endif %}" {{ block.shopify_attributes }}>
          <button class="accordion__button" type="button" data-accordion-button aria-expanded="{% if forloop.first %}true{% else %}false{% endif %}">
            {{ block.settings.question }} {% render 'icon', icon: 'chevron-down' %}
          </button>
          <div class="accordion__content">
            <p>{{ block.settings.answer }}</p>
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "FAQ content",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Häufige Fragen zu Edelpop" },
    { "type": "textarea", "id": "intro", "label": "Intro", "default": "Produkte, Zutaten, Versand, Lagerung und Handel kompakt erklärt." }
  ],
  "blocks": [
    {
      "type": "faq",
      "name": "FAQ item",
      "settings": [
        { "type": "text", "id": "question", "label": "Question", "default": "Was ist Edelpop?" },
        { "type": "textarea", "id": "answer", "label": "Answer", "default": "Edelpop ist ein moderner Premium-Snack aus geröstetem Makhana / Foxnuts mit leichtem Crunch und drei klaren Sorten." }
      ]
    }
  ]
}
{% endschema %}
