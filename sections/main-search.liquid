<section class="section">
  <div class="page-width stack">
    <div class="search-hero">
      <div class="search-hero__shell card">
        <div class="stack">
          <span class="eyebrow">{{ 'accessibility.search' | t }}</span>
          <h1>{{ section.settings.heading }}</h1>
          <p class="lead">{{ section.settings.text }}</p>
        </div>
        <div>
          <form action="{{ routes.search_url }}" method="get" class="search-form">
            <div class="field">
              <input type="search" name="q" value="{{ search.terms | escape }}" placeholder="{{ 'general.navigation.search_placeholder' | t }}">
            </div>
            <button class="btn btn--primary" type="submit">{{ 'accessibility.search' | t }}</button>
          </form>
        </div>
      </div>
    </div>

    {%- if search.performed -%}
      {%- if search.results_count > 0 -%}
        <div class="product-grid grid">
          {%- for item in search.results -%}
            {%- if item.object_type == 'product' -%}
              {% render 'product-card', product: item %}
            {%- else -%}
              <article class="editorial-card card">
                <div class="editorial-card__content stack">
                  <span class="eyebrow">{{ item.object_type }}</span>
                  <h3><a href="{{ item.url }}">{{ item.title }}</a></h3>
                  <p>{{ item.content | strip_html | truncatewords: 22 }}</p>
                </div>
              </article>
            {%- endif -%}
          {%- endfor -%}
        </div>
      {%- else -%}
        <div class="card empty-state">
          <p>{{ 'general.empty.search' | t }}</p>
        </div>
      {%- endif -%}
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Main search",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Finde Sorten, Seiten und Stories." },
    { "type": "textarea", "id": "text", "label": "Text", "default": "Die Suche ist bewusst klar gehalten und funktioniert für Produkte, Seiten und Journal-Inhalte." }
  ]
}
{% endschema %}
