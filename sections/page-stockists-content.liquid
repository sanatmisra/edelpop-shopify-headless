<section class="section">
  <div class="page-width stack">
    <div class="stack">
      <span class="eyebrow">Stockists</span>
      <h1>{{ section.settings.heading }}</h1>
      <p class="lead">{{ section.settings.intro }}</p>
    </div>
    <div class="benefits-grid grid">
      {%- for block in section.blocks -%}
        <div class="card" style="padding: 1rem;" {{ block.shopify_attributes }}>
          <div class="stack">
            <span class="eyebrow">{{ block.settings.region }}</span>
            <h3>{{ block.settings.title }}</h3>
            <p>{{ block.settings.text }}</p>
          </div>
        </div>
      {%- endfor -%}
    </div>
    <a class="btn btn--primary" href="/pages/contact">Edelpop in deiner Nähe?</a>
  </div>
</section>

{% schema %}
{
  "name": "Stockists content",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Wo du Edelpop findest" },
    { "type": "textarea", "id": "intro", "label": "Intro", "default": "Platzhalter für Regionen, Online-Shops und Retail-Partner." }
  ],
  "blocks": [
    {
      "type": "stockist",
      "name": "Stockist",
      "settings": [
        { "type": "text", "id": "region", "label": "Region", "default": "Berlin" },
        { "type": "text", "id": "title", "label": "Title", "default": "Retailer Placeholder" },
        { "type": "textarea", "id": "text", "label": "Text", "default": "Adresse oder Shop-Info hier ergänzen." }
      ]
    }
  ]
}
{% endschema %}
