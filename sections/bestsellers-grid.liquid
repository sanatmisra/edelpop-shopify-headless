<section class="section">
  <div class="page-width stack">
    <div class="cluster section-heading-row" style="justify-content: space-between; align-items: end;">
      {% render 'section-heading', eyebrow: section.settings.eyebrow, heading: section.settings.heading, text: section.settings.text %}
      <a class="btn btn--secondary" href="{{ section.settings.link }}">{{ section.settings.link_label }}</a>
    </div>
    <div class="product-grid grid">
      {%- assign featured_collection = section.settings.collection -%}
      {%- if featured_collection != blank and featured_collection.products_count > 0 -%}
        {%- for product in featured_collection.products limit: section.settings.products_to_show -%}
          {% render 'product-card', product: product %}
        {%- endfor -%}
      {%- else -%}
        {%- for i in (1..4) -%}
          <article class="product-card card">
            <div class="product-card__media media-shell">{{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}</div>
            <div class="product-card__content stack">
              <h3>Flavor {{ i }}</h3>
              <p>{{ 'product.descriptor' | t }}</p>
              <div class="product-card__meta"><span class="price">€4,90</span><span class="badge">Soon</span></div>
            </div>
          </article>
        {%- endfor -%}
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Bestsellers grid",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Edelpop Bestseller" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Unsere Sorten für den ersten Griff und den schnellen Wiederkauf." },
    { "type": "textarea", "id": "text", "label": "Text", "default": "Klar beschrieben, hochwertig präsentiert und für mobile Entscheidungen schnell erfassbar." },
    { "type": "collection", "id": "collection", "label": "Collection" },
    { "type": "range", "id": "products_to_show", "label": "Products to show", "min": 2, "max": 8, "step": 1, "default": 4 },
    { "type": "text", "id": "link_label", "label": "Link label", "default": "Alle Produkte" },
    { "type": "url", "id": "link", "label": "Link" }
  ],
  "presets": [
    { "name": "Bestsellers grid" }
  ]
}
{% endschema %}
